{
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/gerar-planilha", "dest": "/api/gerar-planilha.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}