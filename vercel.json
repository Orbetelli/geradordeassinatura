{
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "api/ia-diagnostico.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/gerar-planilha",
      "dest": "/api/gerar-planilha.py"
    },
    {
      "src": "/api/ia-diagnostico",
      "dest": "/api/ia-diagnostico.js"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/script.js",
      "dest": "/script.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}